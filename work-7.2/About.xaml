<Window x:Class="work_7._2.About"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:work_7._2"
        mc:Ignorable="d"
        Title="About" Height="300" Width="370" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Icon="/among_us_player_orange_icon_156939 (1).ico">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="Black"/>
            <GradientStop Color="#FF8C2222" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Label Content="Developer:" FontFamily="Goudy Stout" Foreground="#FFE0E0E0" FontSize="14" FontWeight="Bold"/>
            <Label Content="Maya Polevaya (Kimariv)" FontFamily="Goudy Stout" Foreground="#FFE0E0E0" FontSize="11"/>
            <Label Content="Help:" FontFamily="Goudy Stout" Foreground="#FFE0E0E0" FontSize="14" FontWeight="Bold"/>
            <Label Content="Lomova L.A." FontFamily="Goudy Stout" Foreground="#FFE0E0E0" FontSize="11"/>
            <TextBlock Margin="4">
            <Hyperlink NavigateUri="https://github.com/naggets394-spec" FontFamily="Goudy Stout" Foreground="#FFE0E0E0" FontSize="11">Github</Hyperlink>
            </TextBlock>
            <Label></Label>
            <Button Content="Close" Foreground="#FF771D1D" FontFamily="Goudy Stout" FontSize="11" Click="Button_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="7"></Setter>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
