<Window x:Class="work_7._2.Input"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:work_7._2"
        mc:Ignorable="d"
        Title="Input" Height="300" Width="270" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Icon="/among_us_player_orange_icon_156939 (1).ico">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="Black"/>
            <GradientStop Color="#FF8C2222" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Label Content="Number One" FontFamily="Goudy Stout" Foreground="#FFE0E0E0"/>
            <TextBox x:Name="TextBoxVal1" Width="200"/>
            <Label Content="Number Two" FontFamily="Goudy Stout" Foreground="#FFE0E0E0"/>
            <TextBox x:Name="TextBoxVal2" Width="200"/>
            <Separator Margin="0, 15"/>
            <RadioButton x:Name="rbComp" Content="Composition" FontFamily="Goudy Stout" Foreground="#FFE0E0E0" Margin="10, 5"/>
            <RadioButton x:Name="rbPow" Content="Power" FontFamily="Goudy Stout" Foreground="#FFE0E0E0" Margin="10, 5"/>
            <RadioButton x:Name="rbAver" Content="Average" FontFamily="Goudy Stout" Foreground="#FFE0E0E0" Margin="10, 5"/>
            <Button Content="Confirm" Foreground="#FF771D1D" FontFamily="Goudy Stout" FontSize="12" Click="Button_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="7"></Setter>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
